# Calendarr config
# SvelteKit Node adapter
PORT=3000
HOST=0.0.0.0

# Timezone used for embed day-grouping and as the default for new schedules.
TZ=Australia/Melbourne

# Date format used by the web UI (date-fns tokens).
# Examples: dd/MM/yyyy HH:mm (default), MM/dd/yyyy hh:mm a, yyyy-MM-dd HH:mm
CALENDARR_DATE_FORMAT=dd/MM/yyyy HH:mm

# SQLite location. In the container this is /config/calendarr.db (mounted volume).
CALENDARR_DB_PATH=./.data/calendarr.db

# User/group the container drops privileges to at startup.
# Unraid defaults (99/100 = nobody/users) work out of the box.
# Other Linux hosts: set to your host user, typically `id -u` / `id -g` (often 1000/1000).
PUID=99
PGID=100
